<Window x:Class="Sensing4UDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensing4U Dashboard"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Load"
                          Click="LoadMenuItem_Click"/>
                <MenuItem Header="_Save"
                          Click="SaveMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="E_xit"
                          Click="ExitMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PreviousDataSetButton"
                            Grid.Column="0"
                            Content="◀ Previous"
                            Width="110"
                            Height="30"
                            Click="PreviousDataSetButton_Click"/>

                    <TextBlock x:Name="CurrentDataSetTextBlock"
                               Grid.Column="1"
                               Text="Current Dataset: Sample Sensor Data"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="14"/>

                    <Button x:Name="NextDataSetButton"
                            Grid.Column="2"
                            Content="Next ▶"
                            Width="110"
                            Height="30"
                            Click="NextDataSetButton_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Lower Bound:"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="LowerBoundTextBox"
                             Grid.Column="1"
                             Height="26"
                             Margin="0,0,15,0"/>

                    <TextBlock Grid.Column="2"
                               Text="Upper Bound:"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="UpperBoundTextBox"
                             Grid.Column="3"
                             Height="26"
                             Margin="0,0,15,0"/>

                    <Button x:Name="ApplyBoundsButton"
                            Grid.Column="4"
                            Content="Apply Bounds"
                            Width="110"
                            Height="28"
                            Click="ApplyBoundsButton_Click"/>

                    <StackPanel Grid.Column="6"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="Average:"
                                   FontWeight="Bold"
                                   Margin="0,0,5,0"/>

                        <TextBlock x:Name="AverageTextBlock"
                                   Text="0.00"
                                   Width="80"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid x:Name="SensorDataGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="All"
                      HeadersVisibility="All"
                      LoadingRow="SensorDataGrid_LoadingRow"

                      Margin="0,0,0,10"/>

            <Border Grid.Row="3"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    Padding="8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Margin="0,0,20,0"
                                VerticalAlignment="Center">

                        <Rectangle Width="18"
                                   Height="18"
                                   Fill="LightBlue"
                                   Stroke="Black"
                                   Margin="0,0,5,0"/>

                        <TextBlock Text="Below Range"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,0,20,0"
                                VerticalAlignment="Center">

                        <Rectangle Width="18"
                                   Height="18"
                                   Fill="LightGreen"
                                   Stroke="Black"
                                   Margin="0,0,5,0"/>

                        <TextBlock Text="Acceptable"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Margin="0,0,20,0"
                                VerticalAlignment="Center">

                        <Rectangle Width="18"
                                   Height="18"
                                   Fill="LightCoral"
                                   Stroke="Black"
                                   Margin="0,0,5,0"/>

                        <TextBlock Text="Above Range"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusMessageTextBlock"
                               Grid.Column="3"
                               Text="Ready"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontStyle="Italic"/>
                </Grid>
            </Border>

        </Grid>
    </DockPanel>
</Window>